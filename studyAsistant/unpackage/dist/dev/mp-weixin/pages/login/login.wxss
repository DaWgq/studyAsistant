.login-container.data-v-e4e4508d {
  min-height: 100vh;
  background: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24px;
}
.login-content.data-v-e4e4508d {
  width: 100%;
  max-width: 400px;
}

/* Logo 区域 */
.logo-section.data-v-e4e4508d {
  text-align: center;
  margin-bottom: 48px;
}
.logo-icon.data-v-e4e4508d {
  font-size: 64px;
  margin-bottom: 16px;
}
.logo-title.data-v-e4e4508d {
  display: block;
  font-size: 24px;
  font-weight: 700;
  color: #ffffff;
  margin-bottom: 8px;
}
.logo-subtitle.data-v-e4e4508d {
  display: block;
  font-size: 14px;
  color: rgba(255, 255, 255, 0.8);
}

/* 表单区域 */
.form-section.data-v-e4e4508d {
  background-color: #ffffff;
  border-radius: 16px;
  padding: 32px 24px;
  box-shadow: 0 10px 40px rgba(0, 0, 0, 0.1);
}
.form-item.data-v-e4e4508d {
  margin-bottom: 24px;
}
.input-label.data-v-e4e4508d {
  display: flex;
  align-items: center;
  margin-bottom: 8px;
  font-size: 14px;
  color: #374151;
  font-weight: 500;
}
.label-icon.data-v-e4e4508d {
  margin-right: 6px;
  font-size: 16px;
}
.form-input.data-v-e4e4508d {
  width: 100%;
  height: 48px;
  background-color: #f3f4f6;
  border-radius: 12px;
  padding: 0 16px;
  font-size: 15px;
  border: 1px solid transparent;
  transition: all 0.3s;
}
.form-input.data-v-e4e4508d:focus {
  background-color: #ffffff;
  border-color: #3b82f6;
}
.input-placeholder.data-v-e4e4508d {
  color: #9ca3af;
}

/* 登录按钮 */
.login-btn.data-v-e4e4508d {
  width: 100%;
  height: 48px;
  background: linear-gradient(135deg, #3b82f6, #2563eb);
  color: #ffffff;
  font-size: 16px;
  font-weight: 600;
  border-radius: 12px;
  border: none;
  margin-top: 8px;
  box-shadow: 0 4px 12px rgba(59, 130, 246, 0.3);
}
.login-btn.data-v-e4e4508d:active {
  opacity: 0.9;
}

/* 提示区域 */
.tips-section.data-v-e4e4508d {
  margin-top: 24px;
  padding-top: 24px;
  border-top: 1px solid #f3f4f6;
  text-align: center;
}
.tips-title.data-v-e4e4508d {
  display: block;
  font-size: 12px;
  color: #6b7280;
  margin-bottom: 8px;
}
.tips-text.data-v-e4e4508d {
  display: block;
  font-size: 12px;
  color: #9ca3af;
  margin-top: 4px;
}